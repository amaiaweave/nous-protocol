PORT=3000

# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_long_random_string

# Railway auto-sets this when PostgreSQL plugin is added
DATABASE_URL=postgresql://user:pass@host:5432/nous

# github.com/settings/tokens → New token → no scopes needed
GITHUB_TOKEN=

# Solana RPC
SOLANA_RPC=https://api.mainnet-beta.solana.com

# app.pinata.cloud → API Keys → New Key → Admin → JWT
PINATA_JWT=

# CORS — your frontend URL
FRONTEND_URL=https://nous-steel.vercel.app
